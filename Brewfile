# Cross-platform CLI tools (macOS + Linux via Homebrew)
# Install with:  brew bundle --file=Brewfile

brew "stow"     # symlink manager — used by install.sh

cask "hammerspoon"
brew "ripgrep"  # fast grep (rg) — used by nvim/telescope
brew "fd"       # fast find — used by nvim/telescope file & dir pickers
brew "neovim"
brew "zellij"
brew "lazygit"
brew "eza"
brew "zoxide"
